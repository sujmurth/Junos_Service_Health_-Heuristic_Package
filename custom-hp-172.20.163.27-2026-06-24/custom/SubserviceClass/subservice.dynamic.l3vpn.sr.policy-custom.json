    "level": "DEGRADED",
    "priority": 255
   }
  },
  {
   "type": "DEP_TYPE_METRIC",
   "label": "sr-policy-list",
   "evalExpression": "metric.l3vpn.sr.policies.list",
   "paramMap": {
    "device": "device",
    "vpnAddr": "vpnAddr",
    "vrf": "vpnServiceId"
   }
  }
 ],
