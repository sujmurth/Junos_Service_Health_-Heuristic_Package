{
 "id": "subservice.dynamic.l3vpn.sr.policy custom",
 "name": "subservice.dynamic.l3vpn.sr.policy",
 "namespace": "custom",
 "description": "Monitors both static and dynamically initiated policy",
 "params": [
  {
   "name": "device"
  },
  {
   "name": "vpnServiceId"
  },
  {
   "name": "vpnAddr"
  }
 ],
 "rootExpressions": [
  {
   "evalExpression": "sr_policy_oper_up"
  }
 ],
 "dynamicConfig": {
  "ruleId": "rule.dynamic.sr.odn.policy custom",
  "ruleParams": {
   "device": "device",
   "sr-policy-list": "sr-policy-list",
   "vpnServiceId": "vpnServiceId"
  },
  "ruleTriggerConditions": {
   "activate": "Len(sr-policy-list) \u003e 0 ",
   "deactivate": "Len(sr-policy-list) == 0 || Len(sr-policy-list) \u003e 100",
   "update": "Delta(sr-policy-list)"
  }
 },
 "dependencies": [
